<style>
  /* ── Auth-Seite Layout & Form ─────────────────────────────────────── */
  .auth-flash-wrap {
    max-width: 460px;
    margin: 1.25rem auto 0;
    padding: 0 1.25rem;
  }

  .auth-wrap {
    max-width: 460px;
    margin: -120px auto 4rem;
    padding: 0 1.25rem;
    position: relative;
    z-index: 5;
  }

  .auth-card {
    background: #fff;
    border: 1.5px solid #e0ddd6;
    border-radius: 1rem;
    padding: 2.5rem 2.25rem 2.25rem;
    box-shadow: 0 18px 48px rgba(0,0,0,0.12);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    color: #1a1a1a;
  }

  .auth-eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #9a9080;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .auth-title {
    font-size: 1.6rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 0.4rem;
    line-height: 1.2;
  }

  .auth-subtitle {
    font-size: 0.9rem;
    color: #6b6b6b;
    margin-bottom: 2rem;
  }

  .auth-field { margin-bottom: 1.1rem; }

  .auth-field label {
    display: block;
    font-size: 0.78rem;
    font-weight: 600;
    color: #2a2a28;
    margin-bottom: 0.4rem;
    letter-spacing: 0.02em;
  }

  .auth-field input[type="email"],
  .auth-field input[type="password"] {
    width: 100%;
    border: 1.5px solid #e0ddd6;
    border-radius: 0.625rem;
    padding: 0.7rem 0.9rem;
    font-size: 0.95rem;
    background: #fbfaf6;
    transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
    font-family: inherit;
    color: #1a1a1a;
  }

  .auth-field input[type="email"]:focus,
  .auth-field input[type="password"]:focus {
    outline: none;
    border-color: #1a1a1a;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(26,26,26,0.06);
  }

  .auth-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin: 0.25rem 0 1.5rem;
    font-size: 0.85rem;
  }

  .auth-remember {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #2a2a28;
    user-select: none;
  }

  .auth-remember input[type="checkbox"] {
    width: 16px;
    height: 16px;
    accent-color: #1a1a1a;
    cursor: pointer;
  }

  .auth-link {
    color: #6b6b6b;
    text-decoration: none;
    border-bottom: 1px dotted #c8c2b6;
    transition: color 0.15s, border-color 0.15s;
  }
  .auth-link:hover { color: #1a1a1a; border-bottom-color: #1a1a1a; }

  .auth-submit {
    width: 100%;
    background: #1a1a1a;
    color: #fff;
    border: none;
    border-radius: 0.625rem;
    padding: 0.85rem 1rem;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    transition: background 0.15s, transform 0.15s;
    font-family: inherit;
  }
  .auth-submit:hover { background: #2d2d2d; transform: translateY(-1px); }

  .auth-footer {
    margin-top: 1.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid #ececec;
    text-align: center;
    font-size: 0.78rem;
    color: #9a9080;
  }
</style>

<div class="auth-wrap">
  <div class="auth-card">
    <p class="auth-eyebrow">Admin-Login</p>
    <h1 class="auth-title">Willkommen zurück</h1>
    <p class="auth-subtitle">Bitte melden Sie sich an, um den Admin-Bereich zu nutzen.</p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { novalidate: true }) do |f| %>

      <div class="auth-field">
        <%= f.label :email, "E-Mail-Adresse" %>
        <%= f.email_field :email,
                          autofocus: true,
                          autocomplete: "email",
                          placeholder: "name@firma.de" %>
      </div>

      <div class="auth-field">
        <%= f.label :password, "Passwort" %>
        <%= f.password_field :password,
                             autocomplete: "current-password",
                             placeholder: "••••••••" %>
      </div>

      <div class="auth-row">
        <% if devise_mapping.rememberable? %>
          <label class="auth-remember">
            <%= f.check_box :remember_me %>
            <span>Angemeldet bleiben</span>
          </label>
        <% else %>
          <span></span>
        <% end %>

        <% if devise_mapping.recoverable? && controller_name != "passwords" %>
          <%= link_to "Passwort vergessen?", new_password_path(resource_name), class: "auth-link" %>
        <% end %>
      </div>

      <%= f.submit "Anmelden", class: "auth-submit" %>
    <% end %>

    <div class="auth-footer">
      © <%= Date.current.year %> Satellite Office
    </div>
  </div>
</div>
