<%# Step 3: Erreichbarkeit %>
<h2 class="conf-question">Während der Arbeit auch erreichbar für Ihre Kunden sein?</h2>

<%= form_with url: configurator_step_path(config.share_token, 3),
              method: :patch, id: "step-form",
              data: { controller: "card-select" } do %>

  <%# Zeile 1: Hauptauswahl (radio, single-select) %>
  <% if @main_products.any? %>
    <div class="conf-card-grid conf-card-grid--2col"
         data-card-select-target="grid"
         data-card-select-mode-value="radio-optional">
      <%= render "configurator/shared/product_row",
                 products: @main_products,
                 selected_ids: @selected_addon_ids,
                 input_name: "addon_ids[]",
                 selection_mode: "radio",
                 dark: false,
                 config: config %>

      <%# "Kein Service" Option %>
      <% no_selected = @main_products.none? { |p| @selected_addon_ids.include?(p.id) } %>
      <div class="conf-card <%= 'is-selected' if no_selected %>"
           data-card-select-target="card"
           data-value="" data-no-selection="true"
           data-select-group="main">
        <div class="conf-card__body" style="min-height:100px; display:flex; flex-direction:column; justify-content:space-between;">
          <div class="conf-card__radio mb-2">
            <div class="conf-card__radio-dot"></div>
            <span>Kein Service</span>
          </div>
          <div class="conf-card__price-row">
            <span class="conf-card__price-label">Preis</span>
            <div class="conf-card__price">0 <span class="conf-card__period">/ Monat</span></div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%# Zeile 2: Zusatz-Addons (checkboxen, erscheint nur wenn zugewiesen) %>
  <% if @addon_products.any? %>
    <p class="conf-section-title mt-4">Addons</p>
    <div class="conf-card-grid conf-card-grid--2col"
         data-card-select-target="grid"
         data-card-select-mode-value="checkbox">
      <%= render "configurator/shared/product_row",
                 products: @addon_products,
                 selected_ids: @selected_addon_ids,
                 input_name: "addon_ids[]",
                 selection_mode: "checkbox",
                 dark: false,
                 config: config %>
    </div>
  <% end %>

<% end %>
