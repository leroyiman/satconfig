<%# Step 5: Membership %>
<h2 class="conf-question">Benötigen Sie einen Coworking-Zugang?</h2>

<%= form_with url: configurator_step_path(config.share_token, 5),
              method: :patch, id: "step-form",
              data: { controller: "card-select", "card-select-mode-value": "radio-optional" } do %>

  <%# Zeile 1: Membership-Optionen (radio-optional) %>
  <div class="conf-card-grid" data-card-select-target="grid">

    <%# "Kein Membership" Option %>
    <% no_selection = @main_products.none? { |p| @selected_addon_ids.include?(p.id) } &&
                      @addon_products.none? { |p| @selected_addon_ids.include?(p.id) } %>
    <div class="conf-card <%= 'is-selected' if no_selection %>"
         data-card-select-target="card"
         data-value="" data-no-selection="true">
      <div class="conf-card__body" style="min-height:100px; display:flex; flex-direction:column; justify-content:space-between;">
        <div class="conf-card__radio mb-2">
          <div class="conf-card__radio-dot"></div>
          <span>Kein Membership</span>
        </div>
        <div class="conf-card__price-row">
          <span class="conf-card__price-label">Preis</span>
          <div class="conf-card__price">0 <span class="conf-card__period">/ Monat</span></div>
        </div>
      </div>
    </div>

    <%= render "configurator/shared/product_row",
               products: @main_products,
               selected_ids: @selected_addon_ids,
               input_name: "addon_ids[]",
               selection_mode: "radio",
               dark: false,
               config: config %>
  </div>

  <%# Zeile 2: Addons %>
  <% if @addon_products.any? %>
    <p class="conf-section-title mt-4">Addons</p>
    <div class="conf-card-grid" data-card-select-target="grid">
      <%= render "configurator/shared/product_row",
                 products: @addon_products,
                 selected_ids: @selected_addon_ids,
                 input_name: "addon_ids[]",
                 selection_mode: "checkbox",
                 dark: false,
                 config: config %>
    </div>
  <% end %>

<% end %>
