<%# Step 5: Membership %>

<h2 class="conf-question">Benötigen Sie einen Coworking-Zugang?</h2>

<%= form_with url: configurator_step_path(config.share_token, 5),
              method: :patch,
              id: "step-form",
              data: { controller: "card-select", "card-select-mode-value": "radio-optional" } do |f| %>

  <% selected_id = @selected_addon_ids.first %>

  <div class="conf-card-grid" data-card-select-target="grid">

    <%# "Kein Membership" Option %>
    <% no_selection = selected_id.nil? %>
    <div class="conf-card <%= 'is-selected' if no_selection %>"
         data-card-select-target="card"
         data-value=""
         data-no-selection="true">
      <div class="conf-card__body" style="min-height:120px; display:flex; flex-direction:column; justify-content:space-between;">
        <div class="conf-card__radio mb-2">
          <div class="conf-card__radio-dot"></div>
          <span>Kein Membership</span>
        </div>
        <div class="conf-card__price-row">
          <span class="conf-card__price-label">Preis</span>
          <div class="conf-card__price">0 <span class="conf-card__period">/ Monat</span></div>
        </div>
      </div>
    </div>

    <% @membership_options.each do |option| %>
      <%
        is_selected = selected_id == option.id
        ph    = addon_price_hash(option)
        name  = option.effective_name("de") || option.effective_attr("name")
        desc  = option.effective_description("de")
        features = desc.present? ? Nokogiri::HTML(desc).css("li").map(&:text) : []
        is_popular = option.crm_attributes["popular"] == true
      %>
      <div class="conf-card <%= 'is-selected' if is_selected %>"
           data-card-select-target="card"
           data-value="<%= option.id %>"
           data-input-name="addon_ids[]">

        <div class="conf-card__body">
          <div class="conf-card__radio mb-2">
            <div class="conf-card__radio-dot"></div>
            <span><%= name %></span>
            <% if is_popular %>
              <span class="badge-popular ms-auto">Beliebt</span>
            <% end %>
          </div>

          <% if features.any? %>
            <ul class="conf-card__features">
              <% features.first(5).each do |feat| %><li><%= feat %></li><% end %>
            </ul>
          <% elsif desc.present? %>
            <p class="conf-card__description"><%= desc.gsub(/<[^>]+>/, "").truncate(100) %></p>
          <% end %>

          <div class="conf-card__price-row">
            <span class="conf-card__price-label">Preis</span>
            <div class="conf-card__price">
              <% if ph[:original] %>
                <span class="conf-card__price-original">
                  <%= format_conf_price(ph[:original], config.currency) %>
                </span>
              <% end %>
              <span><%= format_conf_price(ph[:current], config.currency) %></span>
              <span class="conf-card__period">/ Monat</span>
              <% if ph[:discount_percent] %>
                <span class="badge-discount">-<%= ph[:discount_percent] %>%</span>
              <% end %>
            </div>
          </div>
        </div>

        <input type="checkbox" name="addon_ids[]" value="<%= option.id %>"
               <%= "checked" if is_selected %> style="display:none;">
      </div>
    <% end %>
  </div>

<% end %>
