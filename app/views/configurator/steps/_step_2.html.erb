<%# Step 2: Typ – Hauptprodukt wählen %>
<h2 class="conf-question">Welche Art von Geschäftsadresse benötigen Sie?</h2>

<%= form_with url: configurator_step_path(config.share_token, 2),
              method: :patch, id: "step-form",
              data: { controller: "card-select", "card-select-mode-value": "radio" } do %>

  <%# Zeile 1: Hauptprodukte (radio) %>
  <% if @main_products.any? %>
    <div class="conf-card-grid" data-card-select-target="grid">
      <%= render "configurator/shared/product_row",
                 products: @main_products,
                 selected_ids: [config.product_id].compact,
                 input_name: "product_id",
                 selection_mode: "radio",
                 dark: false,
                 config: config %>
    </div>
  <% else %>
    <p class="text-muted">Noch keine Produkte für diese Location verfügbar.</p>
  <% end %>

  <%# Zeile 2: Addons (erscheint nur wenn zugewiesen) %>
  <% if @addon_products.any? %>
    <p class="conf-section-title mt-4">Addons</p>
    <div class="conf-card-grid" data-card-select-target="grid">
      <%= render "configurator/shared/product_row",
                 products: @addon_products,
                 selected_ids: @selected_addon_ids || [],
                 input_name: "addon_ids[]",
                 selection_mode: "checkbox",
                 dark: false,
                 config: config %>
    </div>
  <% end %>
<% end %>
