<%# Step 4: Meetings %>
<h2 class="conf-question">Meetings</h2>

<%= form_with url: configurator_step_path(config.share_token, 4),
              method: :patch, id: "step-form",
              data: { controller: "card-select meetings-calculator",
                      "card-select-mode-value": "radio-optional",
                      "meetings-calculator-packages-value": @main_products.map { |p|
                        { id: p.id, price: p.effective_attr("price_per_location").to_f }
                      }.to_json } do %>

  <%# Calculator %>
  <div class="conf-calculator">
    <p class="conf-calculator__title">Ermitteln Sie ihr durchschnittliches Meeting Aufkommen</p>
    <div class="conf-calculator__fields">
      <div class="conf-calculator__field">
        <label>Durchschnittliche Meetings pro Monat</label>
        <input type="number" min="0" placeholder="Geschätzte Anzahl"
               data-meetings-calculator-target="meetings"
               data-action="input->meetings-calculator#calculate">
      </div>
      <div class="conf-calculator__field">
        <label>Durchschnittliche Personen pro Meeting</label>
        <input type="number" min="0" placeholder="Geschätzte Anzahl"
               data-meetings-calculator-target="persons"
               data-action="input->meetings-calculator#calculate">
      </div>
      <button type="button" class="conf-calculator__btn"
              data-action="meetings-calculator#recommend">
        Empfehlung ermitteln
      </button>
    </div>
  </div>

  <%# Zeile 1: Meeting-Pakete (radio-optional) %>
  <% if @main_products.any? %>
    <p class="conf-section-title">Optionen</p>
    <div class="conf-card-grid" data-card-select-target="grid">
      <%= render "configurator/shared/product_row",
                 products: @main_products,
                 selected_ids: @selected_addon_ids,
                 input_name: "addon_ids[]",
                 selection_mode: "radio",
                 dark: false,
                 config: config %>
    </div>
  <% end %>

  <%# Zeile 2: Zusatz-Addons %>
  <% if @addon_products.any? %>
    <p class="conf-section-title mt-4">Addons</p>
    <div class="conf-card-grid" data-card-select-target="grid">
      <%= render "configurator/shared/product_row",
                 products: @addon_products,
                 selected_ids: @selected_addon_ids,
                 input_name: "addon_ids[]",
                 selection_mode: "checkbox",
                 dark: false,
                 config: config %>
    </div>
  <% end %>

<% end %>
