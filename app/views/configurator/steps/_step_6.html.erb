<%# Step 6: Zusammenfassung + Upgrade-Angebote (dunkel) %>

<%= form_with url: configurator_step_path(config.share_token, 6),
              method: :patch, id: "step-form",
              data: { controller: "card-select", "card-select-mode-value": "checkbox" } do %>

  <div class="conf-summary-layout">

    <%# ── Linke Spalte: Zusammenfassung ──────────────────────────────── %>
    <div>
      <h2 class="conf-question mb-4">Zusammenfassung</h2>
      <div class="conf-summary-card">
        <div class="conf-summary-card__total">
          <span>Gesamt</span>
          <span class="conf-summary-card__total-amount">
            <%= format_conf_price(config.total_price, config.currency) %>
          </span>
        </div>
        <div class="text-muted small mb-2">pro Monat</div>

        <div class="conf-summary-card__image" style="padding:0; overflow:hidden;">
          <%= render "configurator/shared/location_image",
                     location: config.location, height: "160px" %>
        </div>

        <% if config.location %>
          <div class="conf-sidebar-section">
            <div class="conf-sidebar-section__label">Adresse</div>
            <div class="conf-sidebar-section__name"><%= config.location.effective_name %></div>
            <div class="conf-sidebar-section__sub"><%= config.location.effective_address %></div>
          </div>
        <% end %>

        <% if config.product %>
          <% pd = config.product_price_display %>
          <div class="conf-sidebar-section">
            <div class="conf-sidebar-section__label">Typ</div>
            <div class="conf-sidebar-section__row">
              <div class="conf-sidebar-section__name">
                <%= config.product.effective_attr("name") || config.product.type %>
              </div>
              <div class="conf-sidebar-section__price">
                <%= format_conf_price(pd[:current], config.currency) %>
              </div>
            </div>
          </div>
        <% end %>

        <% { 3 => "Erreichbarkeit", 4 => "Meetings", 5 => "Membership" }.each do |s, label| %>
          <% sadds = config.addons_for_step(s) %>
          <% next if sadds.empty? %>
          <div class="conf-sidebar-section">
            <div class="conf-sidebar-section__label"><%= label %></div>
            <% sadds.each do |addon| %>
              <% ad = config.addon_price_display(addon) %>
              <div class="conf-sidebar-section__row mb-1">
                <span class="conf-sidebar-section__name" style="font-size:0.82rem;">
                  <%= addon.effective_attr("name") %>
                </span>
                <span class="conf-sidebar-section__price" style="font-size:0.82rem;">
                  <%= format_conf_price(ad[:current], config.currency) %>
                </span>
              </div>
            <% end %>
          </div>
        <% end %>

        <div class="conf-summary-card__total mt-3 pt-3 border-top">
          <span>Gesamt</span>
          <span class="conf-summary-card__total-amount" style="font-size:1.5rem;">
            <%= format_conf_price(config.total_price, config.currency) %>
          </span>
        </div>
        <div class="text-muted small mb-3">pro Monat</div>
        <button type="submit" form="step-form" class="conf-btn-next conf-btn-next--full">Weiter</button>
      </div>
    </div>

    <%# ── Rechte Spalte: Upgrade-Angebote (dunkel) ───────────────────── %>
    <div>
      <h2 class="conf-question mb-4">Upgrade Angebote</h2>
      <div class="d-flex flex-column gap-3" data-card-select-target="grid">

        <% all_upgrades = (@main_products + @addon_products).uniq %>
        <% if all_upgrades.empty? %>
          <p class="text-muted small">Keine weiteren Upgrade-Angebote verfügbar.</p>
        <% else %>
          <%= render "configurator/shared/product_row",
                     products: all_upgrades,
                     selected_ids: @selected_upgrade_ids || [],
                     input_name: "upgrade_ids[]",
                     selection_mode: "checkbox",
                     dark: true,
                     config: config %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
