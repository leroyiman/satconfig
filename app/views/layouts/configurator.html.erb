<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Geschäftsadresse konfigurieren – Satellite Office</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", media: "all" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="conf-page">

    <%# ── Hero Header mit Step-Indicator ──────────────────────────────────── %>
    <header class="conf-hero <%= yield(:hero_class) %>">
      <div class="conf-hero__bg" style="background-image: url('https://www.satelliteoffice.de/wp-content/uploads/2025/03/FOP-14.webp'); <%= yield(:hero_bg) %>"></div>
      <div class="conf-hero__content">

        <%# Topbar %>
        <div class="conf-topbar">
          <a href="/" class="conf-topbar__logo">
            <strong>SATELLITE</strong> OFFICE
          </a>
          <p class="conf-topbar__title">Geschäftsadresse konfigurieren</p>
          <a href="mailto:info@satelliteoffice.de" class="conf-topbar__contact">Kontakt</a>
        </div>

        <%# Step Indicator %>
        <% if @config.present? %>
          <%= render "configurator/shared/step_indicator", config: @config, current_step: (@step || @config.current_step) %>
        <% end %>

      </div>
    </header>

    <%# Flash Messages %>
    <% if flash[:alert].present? %>
      <div class="container-fluid px-4 pt-3">
        <div class="alert alert-danger alert-dismissible mb-0" role="alert">
          <%= flash[:alert] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      </div>
    <% end %>

    <%# Main Content %>
    <%= yield %>

  </body>
</html>
