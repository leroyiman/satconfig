<% content_for :breadcrumb do %>
  <li class="breadcrumb-item"><%= link_to "Dashboard", admin_root_path %></li>
  <li class="breadcrumb-item active">Locations & Städte</li>
<% end %>

<h4 class="fw-bold mb-4">
  <i class="fa-solid fa-map-pin text-muted me-2"></i>Locations & Städte
</h4>

<% @cities.each do |city| %>
  <div class="admin-card mb-3">
    <div class="card-header d-flex align-items-center gap-2">
      <i class="fa-solid fa-city text-muted"></i>
      <span class="fw-semibold"><%= city.effective_name %></span>
      <span class="badge bg-light text-muted ms-1"><%= city.effective_currency %></span>
      <span class="badge bg-secondary ms-auto"><%= city.locations.active.count %> Locations</span>
    </div>
    <% if city.locations.active.any? %>
      <div class="table-responsive">
        <table class="table table-sm mb-0 small align-middle">
          <thead class="table-light">
            <tr>
              <th class="ps-3">Name</th>
              <th>Adresse</th>
              <th>Produkte</th>
              <th class="text-center">Im Konfigurator</th>
              <th class="pe-3"></th>
            </tr>
          </thead>
          <tbody>
            <% city.locations.active.order(:name).each do |location| %>
              <% hidden = location.local_attributes["configurator_hidden"] == "true" %>
              <tr class="<%= 'opacity-50' if hidden %>">
                <td class="ps-3 fw-medium">
                  <%= link_to location.effective_name, admin_location_path(location),
                              class: "text-decoration-none text-dark" %>
                  <% if location.local_attributes.except("configurator_hidden").present? %>
                    <span class="badge bg-warning text-dark ms-1" style="font-size:0.55rem">Override</span>
                  <% end %>
                </td>
                <td class="text-muted"><%= location.effective_address&.truncate(50) %></td>
                <td>
                  <span class="badge bg-light text-muted">
                    <%= location.products.active.count %>
                  </span>
                </td>
                <td class="text-center">
                  <% if hidden %>
                    <%= button_to reset_override_admin_location_path(location, field: "configurator_hidden"),
                                  method: :patch,
                                  class: "btn btn-sm btn-outline-success",
                                  title: "Wieder einblenden" do %>
                      <i class="fa-solid fa-eye-slash text-danger me-1"></i>Verborgen
                    <% end %>
                  <% else %>
                    <%= button_to admin_location_path(location),
                                  method: :patch,
                                  params: { location: { local_attributes: { configurator_hidden: "true" } } },
                                  class: "btn btn-sm btn-outline-secondary",
                                  title: "Im Konfigurator verbergen" do %>
                      <i class="fa-solid fa-eye text-success me-1"></i>Sichtbar
                    <% end %>
                  <% end %>
                </td>
                <td class="pe-3 text-end">
                  <%= link_to "Bearbeiten", admin_location_path(location),
                              class: "btn btn-sm btn-outline-secondary" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="card-body text-muted small py-2 ps-3">Keine aktiven Locations</div>
    <% end %>
  </div>
<% end %>

<% if @cities.empty? %>
  <div class="text-center text-muted py-5">
    <i class="fa-solid fa-city mb-3 d-block fs-2"></i>
    Noch keine Städte synchronisiert.
  </div>
<% end %>
