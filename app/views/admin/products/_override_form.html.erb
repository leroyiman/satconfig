<div class="admin-card">
  <div class="card-header d-flex align-items-center justify-content-between">
    <div class="d-flex align-items-center gap-2">
      <i class="fa-solid fa-euro-sign text-muted"></i>
      Preis-Overrides
    </div>
    <% if product.local_attributes.present? %>
      <%= button_to reset_override_admin_product_path(product),
                    method: :patch,
                    class: "btn btn-sm btn-outline-danger",
                    form: { "data-turbo-confirm": "Alle Preis-Overrides zurücksetzen?" } do %>
        <i class="fa-solid fa-rotate-left me-1"></i>Alle zurücksetzen
      <% end %>
    <% end %>
  </div>

  <%# Erklärungs-Box %>
  <div class="mx-3 mt-3 p-2 rounded small"
       style="background:#f0f4ff; border:1px solid #d0dbff; color:#3a4a8a">
    <i class="fa-solid fa-circle-info me-1"></i>
    <strong>CRM-Wert</strong> kommt von Zoho und wird bei jedem Sync aktualisiert.
    <strong>Dein Override</strong> bleibt bestehen – feld leer lassen = CRM-Wert gilt.
  </div>

  <% if overridable.empty? %>
    <div class="card-body text-muted small text-center py-3">
      Keine überschreibbaren Preisfelder für diesen Produkttyp.
    </div>
  <% else %>

    <%# Tabellen-Header %>
    <div class="px-3 pt-3 pb-1">
      <div class="row gx-2 text-muted small fw-semibold border-bottom pb-1">
        <div class="col-4">Feld</div>
        <div class="col-3">CRM-Wert</div>
        <div class="col-3">Dein Override</div>
        <div class="col-2">Status</div>
      </div>
    </div>

    <%# Status-Übersicht vor dem Formular %>
    <div class="px-3 pb-2">
      <% overridable.each do |field| %>
        <% crm_val   = product.crm_attributes[field[:key]] %>
        <% local_val = product.local_attributes[field[:key]] %>
        <div class="row gx-2 align-items-center py-2 border-bottom override-row">
          <div class="col-4 small fw-medium">
            <%= field[:label] %>
            <span class="text-muted ms-1">(<%= field[:unit] %>)</span>
          </div>
          <div class="col-3 crm-value"><%= crm_val.presence || "—" %></div>
          <div class="col-3">
            <% if local_val.present? %>
              <span class="override-value"><%= local_val %></span>
            <% else %>
              <span class="text-muted small">–</span>
            <% end %>
          </div>
          <div class="col-2">
            <% if local_val.present? %>
              <span class="badge bg-warning text-dark" style="font-size:0.65rem">
                Override
              </span>
            <% else %>
              <span class="badge bg-light text-muted" style="font-size:0.65rem">
                CRM
              </span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <%# Override-Formular %>
    <%= form_with url: admin_product_path(product), method: :patch, local: true do |f| %>
      <div class="px-3 pb-1 pt-2">
        <p class="text-muted small mb-2">
          <i class="fa-solid fa-pen me-1"></i>Werte überschreiben:
          Feld leer lassen = Override entfernen (CRM-Wert gilt wieder)
        </p>
        <% overridable.each do |field| %>
          <% local_val = product.local_attributes[field[:key]] %>
          <div class="row gx-2 align-items-center mb-2">
            <div class="col-4">
              <label class="form-label small mb-0 fw-medium"><%= field[:label] %></label>
            </div>
            <div class="col-5">
              <div class="input-group input-group-sm">
                <span class="input-group-text"><%= field[:unit] %></span>
                <%= f.number_field "product[local_attributes][#{field[:key]}]",
                                   value: local_val,
                                   step: field[:step] || "0.01",
                                   min: 0,
                                   placeholder: product.crm_attributes[field[:key]] || "leer = CRM",
                                   class: "form-control #{'border-warning' if local_val.present?}" %>
              </div>
            </div>
            <div class="col-3">
              <% if local_val.present? %>
                <%= button_to reset_override_admin_product_path(product, field: field[:key]),
                              method: :patch,
                              class: "btn btn-sm btn-outline-secondary w-100",
                              title: "Auf CRM-Wert zurücksetzen" do %>
                  <i class="fa-solid fa-rotate-left me-1"></i>Reset
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="px-3 pb-3 pt-2 border-top mt-1">
        <%= f.submit "Overrides speichern",
                     class: "btn btn-primary btn-sm px-4" %>
        <span class="text-muted small ms-2">
          Zoho-Sync überschreibt diese Werte <strong>nicht</strong>.
        </span>
      </div>
    <% end %>

  <% end %>
</div>
