{
  "_documentation": {
    "description": "Dieses Dokument beschreibt alle Webhook-Payloads, die von Zoho CRM an die Satellite Office Konfigurator-API gesendet werden müssen.",
    "endpoint": "POST https://config.satellite-office.com/api/v1/zoho/webhook",
    "authentication": {
      "method": "Bearer Token (HTTP Authorization Header)",
      "header": "Authorization: Bearer <ZOHO_WEBHOOK_SECRET>",
      "note": "Der Token wird einmalig von Satellite Office bereitgestellt und muss bei jedem Request mitgesendet werden."
    },
    "content_type": "application/json",
    "response": {
      "success": { "status": 202, "body": { "status": "accepted" } },
      "auth_error": { "status": 401, "body": { "error": "Unauthorized" } },
      "validation_error": { "status": 422, "body": { "error": "..." } }
    },
    "event_types": [
      "city.created", "city.updated", "city.deleted",
      "location.created", "location.updated", "location.deleted",
      "conference_room.created", "conference_room.updated", "conference_room.deleted",
      "office.created", "office.updated", "office.deleted",
      "virtual_office.created", "virtual_office.updated", "virtual_office.deleted",
      "company_headquarter.created", "company_headquarter.updated", "company_headquarter.deleted",
      "addon.created", "addon.updated", "addon.deleted"
    ],
    "notes": [
      "zoho_id muss die eindeutige Zoho CRM Record ID sein und darf sich nie ändern.",
      "Für *.deleted Events reichen event, entity_type, zoho_id und triggered_at.",
      "translations ist ein Array – alle verfügbaren Sprachversionen auf einmal senden.",
      "Preise immer als String mit Dezimalpunkt übergeben, z.B. '890.00'.",
      "applies_to bei Addons als Array von Typ-Strings: ['Office', 'VirtualOffice', ...]"
    ]
  },

  "examples": {

    "city": {

      "city_created_or_updated": {
        "_comment": "Wird gesendet wenn eine Stadt in Zoho angelegt oder aktualisiert wird.",
        "event": "city.created",
        "entity_type": "city",
        "zoho_id": "CITY-001-ZO",
        "triggered_at": "2026-04-14T08:00:00Z",
        "data": {
          "name": "Berlin",
          "currency": "EUR"
        }
      },

      "city_deleted": {
        "_comment": "Wird gesendet wenn eine Stadt in Zoho gelöscht / deaktiviert wird.",
        "event": "city.deleted",
        "entity_type": "city",
        "zoho_id": "CITY-001-ZO",
        "triggered_at": "2026-04-14T08:05:00Z",
        "data": {}
      }

    },

